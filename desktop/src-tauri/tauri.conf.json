{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ND3X",
  "version": "0.5.4",
  "identifier": "com.nd3x.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ND3X",
        "width": 1280,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/nd3x-backend"],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
