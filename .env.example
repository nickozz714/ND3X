# ND3X back-end environment — OPTIONAL.
#
# On a fresh machine you do NOT need a .env at all: start the back-end and the
# front-end opens a first-time-setup wizard that chooses the base directory and
# database, creates the admin user, configures providers/models, and generates +
# persists the secrets (JWT + Fernet) under ND3X_HOME (default ~/.nd3x).
#
# This file is only for headless/Docker/CI deploys that want to skip the wizard
# and configure everything via the environment. Every value overrides the wizard
# config; empty values are treated as "unset" (the code default applies).
#
# Almost all settings now live in the DATABASE (editable under Application
# Settings → System configuration). Any of them can still be overridden here by
# an environment variable of the same name (e.g. MAX_TOOL_STEPS, LOG_LEVEL,
# MCP_URL); an env override always wins over the DB value.
#
# NOTE: the OpenAI API key and the chat/embedding models are NOT set here — the
# key lives in the provider registry and models come from the routing slots.

# Where bootstrap.json + secrets.json live (default ~/.nd3x). Point this at a
# baked config to run a pre-configured deployment.
# ND3X_HOME=~/.nd3x

# ===============================
# Headless mode (skip the wizard)
# ===============================
# Set to true to run the full stack from env without the setup wizard. You must
# then also provide a database below and the secrets in the next section. With an
# explicit DB set, this is inferred automatically.
# ND3X_CONFIGURED=true

# ===============================
# Secrets (set for headless; otherwise generated by the wizard)
# ===============================
# JWT signing secret (HS256). Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
# Fernet key encrypting provider/mail secrets at rest — MUST stay stable.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MAIL_SECRET_KEY=
# Optional second Fernet key for app-settings encryption (same generator).
SETTINGS_ENCRYPTION_KEY=
# Access-token lifetime in minutes (default 30).
ACCESS_TOKEN_MIN=

# ===============================
# Database (headless; otherwise chosen in the wizard)
# ===============================
# DB_DIALECT: "sqlite" or "mysql". Setting any DB_* value here makes the app run
# in configured mode (no wizard).
# DB_DIALECT=sqlite
# SQLITE_PATH=./db/nd3x.db
# MySQL (only when DB_DIALECT=mysql):
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASS=
# DB_NAME=

# ===============================
# MCP (remote server with search/index)
# ===============================
# Example: http://192.168.1.60:8000/mcp
MCP_URL=
# Leave empty if MCP is open on the LAN.
MCP_BEARER=

# ===============================
# Server
# ===============================
HOST=
PORT=
DEBUG=

# ===============================
# Safety / Limits (all optional — defaults in config.py)
# ===============================
# Maximum planner -> tool -> answer cycles.
MAX_TOOL_STEPS=
# Maximum evaluation cycles (planner -> tool -> evaluate -> tool).
EVALUATION_HOPS=
# Default search fan-out.
MAX_SEARCH_K=
# Max chars returned from files (prevents token explosion).
MAX_FILE_CHARS=
